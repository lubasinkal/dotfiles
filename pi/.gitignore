.pi/agent/pi-hermes-memory/*.db-wal
.pi/agent/pi-hermes-memory/.skills-migrated-to-extension-storage

# Context mode
.pi/context-mode/

# Subagent artifacts
.pi/.pi-subagents/

# Node dependencies
.pi/agent/npm/node_modules/
.pi/agent/npm/package-lock.json
